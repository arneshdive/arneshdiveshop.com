# Database (Neon)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/arneshdiveshop?sslmode=require"

# Auth
JWT_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# Midtrans
MIDTRANS_SERVER_KEY="your-midtrans-server-key"
MIDTRANS_CLIENT_KEY="your-midtrans-client-key"
MIDTRANS_IS_PRODUCTION="false"

# Resend (email)
RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM="noreply@yourdomain.com"

# Vercel Blob
BLOB_READ_WRITE_TOKEN="your-blob-token"

# Midtrans Public Keys (for frontend)
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="your-midtrans-client-key"
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION="false"

# RajaOngkir API v2 (Komerce) - Multiple keys for higher daily limits
RAJAONGKIR_API_KEY="your-primary-api-key"
RAJAONGKIR_API_KEY_2="your-secondary-api-key"
RAJAONGKIR_BASE_URL="https://rajaongkir.komerce.id/api/v1"
